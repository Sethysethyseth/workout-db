# Copy to .env and fill in real values (this file is safe to commit).

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DATABASE"
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/DATABASE"
SESSION_SECRET="use-a-long-random-string"
JWT_SECRET="use-a-long-random-string"

# Optional. Localhost Vite origins are always allowed in dev.
# Comma-separated: add every browser origin that may call this API (prod + previews, etc.).
# CLIENT_ORIGIN=https://workoutdb-beta.vercel.app,https://workout-db-beta-git-main-you.vercel.app
# Second slot if you prefer to keep LAN mobile separate from web:
# CLIENT_ORIGIN_MOBILE=http://YOUR_LAN_IP:5173

# PORT=3000

# Comma-separated emails allowed to GET /feedback (dev review). Leave unset to disable listing.
# FEEDBACK_REVIEWER_EMAILS=you@example.com
