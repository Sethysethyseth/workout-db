generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  passwordHash     String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  workoutTemplates WorkoutTemplate[]
  blockTemplates   BlockTemplate[]
  workoutSessions  WorkoutSession[]
}

model WorkoutTemplate {
  id          Int                @id @default(autoincrement())
  name        String
  description String?
  isPublic    Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises   TemplateExercise[]
  sessions    WorkoutSession[]

  @@index([userId])
  @@index([isPublic])
}

model TemplateExercise {
  id                Int               @id @default(autoincrement())
  order             Int
  exerciseName      String
  targetSets        Int?
  targetReps        String?
  notes             String?
  workoutTemplateId Int
  workoutTemplate   WorkoutTemplate   @relation(fields: [workoutTemplateId], references: [id], onDelete: Cascade)
  sets              WorkoutSet[]
  templateSets      TemplateSet[]
  sessionExercises  SessionExercise[]

  @@unique([workoutTemplateId, order])
  @@index([workoutTemplateId])
}

model TemplateSet {
  id                 Int              @id @default(autoincrement())
  order              Int
  reps               Int?
  weight             Float?
  rpe                Float?
  rir                Int?
  notes              String?
  templateExerciseId Int
  templateExercise   TemplateExercise @relation(fields: [templateExerciseId], references: [id], onDelete: Cascade)

  @@unique([templateExerciseId, order])
  @@index([templateExerciseId])
}

model WorkoutSession {
  id                Int               @id @default(autoincrement())
  performedAt       DateTime          @default(now())
  startedAt         DateTime          @default(now())
  completedAt       DateTime?
  notes             String?
  createdAt         DateTime          @default(now())
  userId            String
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutTemplateId Int?
  workoutTemplate   WorkoutTemplate?  @relation(fields: [workoutTemplateId], references: [id], onDelete: SetNull)
  sets              WorkoutSet[]
  sessionExercises  SessionExercise[]

  @@index([userId])
  @@index([workoutTemplateId])
}

model WorkoutSet {
  id                 Int               @id @default(autoincrement())
  order              Int
  reps               Int?
  weight             Float?
  rpe                Float?
  rir                Int?
  notes              String?
  workoutSessionId   Int
  workoutSession     WorkoutSession    @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  templateExerciseId Int?
  templateExercise   TemplateExercise? @relation(fields: [templateExerciseId], references: [id], onDelete: SetNull)
  sessionExerciseId  Int?
  sessionExercise    SessionExercise?  @relation(fields: [sessionExerciseId], references: [id], onDelete: SetNull)

  @@unique([workoutSessionId, order])
  @@index([workoutSessionId])
  @@index([templateExerciseId])
  @@index([sessionExerciseId])
}

model SessionExercise {
  id                 Int               @id @default(autoincrement())
  order              Int
  exerciseName       String
  targetSets         Int?
  targetReps         String?
  notes              String?
  workoutSessionId   Int
  workoutSession     WorkoutSession    @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  templateExerciseId Int?
  templateExercise   TemplateExercise? @relation(fields: [templateExerciseId], references: [id], onDelete: SetNull)
  sets               WorkoutSet[]

  @@unique([workoutSessionId, order])
  @@index([workoutSessionId])
  @@index([templateExerciseId])
}

model BlockTemplate {
  id              Int            @id @default(autoincrement())
  name            String
  description     String?
  isPublic        Boolean        @default(false)
  durationWeeks   Int?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workouts        BlockWorkout[]

  @@index([userId])
  @@index([isPublic])
}

model BlockWorkout {
  id              Int                    @id @default(autoincrement())
  order           Int
  name            String
  blockTemplateId Int
  blockTemplate   BlockTemplate          @relation(fields: [blockTemplateId], references: [id], onDelete: Cascade)
  exercises       BlockWorkoutExercise[]

  @@unique([blockTemplateId, order])
  @@index([blockTemplateId])
}

model BlockWorkoutExercise {
  id               Int               @id @default(autoincrement())
  order            Int
  exerciseName     String
  targetSets       Int?
  targetReps       String?
  notes            String?
  blockWorkoutId   Int
  blockWorkout     BlockWorkout      @relation(fields: [blockWorkoutId], references: [id], onDelete: Cascade)
  blockWorkoutSets BlockWorkoutSet[]

  @@unique([blockWorkoutId, order])
  @@index([blockWorkoutId])
}

model BlockWorkoutSet {
  id                     Int                  @id @default(autoincrement())
  order                  Int
  reps                   Int?
  weight                 Float?
  rpe                    Float?
  rir                    Int?
  notes                  String?
  blockWorkoutExerciseId Int
  blockWorkoutExercise   BlockWorkoutExercise @relation(fields: [blockWorkoutExerciseId], references: [id], onDelete: Cascade)

  @@unique([blockWorkoutExerciseId, order])
  @@index([blockWorkoutExerciseId])
}
