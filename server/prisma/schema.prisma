generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Optional: use a non-pooled direct connection for migrations if your provider
  // gives you separate URLs (Neon commonly does).
  directUrl = env("DIRECT_URL")
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  displayName      String?
  usernameKey      String?           @unique
  passwordHash     String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  workoutTemplates WorkoutTemplate[]
  blockTemplates   BlockTemplate[]
  workoutSessions  WorkoutSession[]
  feedback         Feedback[]
  userExercises    UserExercise[]
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  String
  message   String
  pagePath  String?
  theme     String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model WorkoutTemplate {
  id          Int                @id @default(autoincrement())
  name        String
  description String?
  isPublic    Boolean            @default(false)
  useRIR      Boolean            @default(false)
  useRPE      Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises   TemplateExercise[]
  sessions    WorkoutSession[]

  @@index([userId])
  @@index([isPublic])
}

model TemplateExercise {
  id                Int               @id @default(autoincrement())
  order             Int
  exerciseName      String
  exerciseId        String?
  exercise          Exercise?         @relation(fields: [exerciseId], references: [id], onDelete: SetNull)
  userExerciseId    Int?
  userExercise      UserExercise?     @relation(fields: [userExerciseId], references: [id], onDelete: SetNull)
  targetSets        Int?
  targetReps        String?
  notes             String?
  workoutTemplateId Int
  workoutTemplate   WorkoutTemplate   @relation(fields: [workoutTemplateId], references: [id], onDelete: Cascade)
  sets              WorkoutSet[]
  templateSets      TemplateSet[]
  sessionExercises  SessionExercise[]

  @@unique([workoutTemplateId, order])
  @@index([workoutTemplateId])
  @@index([exerciseId])
  @@index([userExerciseId])
}

model TemplateSet {
  id                 Int              @id @default(autoincrement())
  order              Int
  reps               Float?
  weight             Float?
  rpe                Float?
  rir                Int?
  notes              String?
  templateExerciseId Int
  templateExercise   TemplateExercise @relation(fields: [templateExerciseId], references: [id], onDelete: Cascade)

  @@unique([templateExerciseId, order])
  @@index([templateExerciseId])
}

model WorkoutSession {
  id                Int               @id @default(autoincrement())
  performedAt       DateTime          @default(now())
  startedAt         DateTime          @default(now())
  completedAt       DateTime?
  /** Display name for quick-log sessions; template-based sessions use the template name. */
  name              String?
  notes             String?
  createdAt         DateTime          @default(now())
  userId            String
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutTemplateId Int?
  workoutTemplate   WorkoutTemplate?  @relation(fields: [workoutTemplateId], references: [id], onDelete: SetNull)
  sets              WorkoutSet[]
  sessionExercises  SessionExercise[]

  @@index([userId])
  @@index([workoutTemplateId])
}

model WorkoutSet {
  id                 Int               @id @default(autoincrement())
  order              Int
  reps               Float?
  weight             Float?
  rpe                Float?
  rir                Int?
  notes              String?
  side               String?
  workoutSessionId   Int
  workoutSession     WorkoutSession    @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  templateExerciseId Int?
  templateExercise   TemplateExercise? @relation(fields: [templateExerciseId], references: [id], onDelete: SetNull)
  sessionExerciseId  Int?
  sessionExercise    SessionExercise?  @relation(fields: [sessionExerciseId], references: [id], onDelete: SetNull)
  blockWorkoutSetId  Int?
  blockWorkoutSet    BlockWorkoutSet?  @relation(fields: [blockWorkoutSetId], references: [id], onDelete: SetNull)

  @@unique([workoutSessionId, order])
  @@index([workoutSessionId])
  @@index([templateExerciseId])
  @@index([sessionExerciseId])
  @@index([blockWorkoutSetId])
}

model SessionExercise {
  id                 Int               @id @default(autoincrement())
  order              Int
  exerciseName       String
  exerciseId         String?
  exercise           Exercise?         @relation(fields: [exerciseId], references: [id], onDelete: SetNull)
  userExerciseId     Int?
  userExercise       UserExercise?     @relation(fields: [userExerciseId], references: [id], onDelete: SetNull)
  targetSets         Int?
  targetReps         String?
  notes              String?
  workoutSessionId   Int
  workoutSession     WorkoutSession    @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  templateExerciseId Int?
  templateExercise   TemplateExercise? @relation(fields: [templateExerciseId], references: [id], onDelete: SetNull)
  sets               WorkoutSet[]

  @@unique([workoutSessionId, order])
  @@index([workoutSessionId])
  @@index([templateExerciseId])
  @@index([exerciseId])
  @@index([userExerciseId])
}

model BlockTemplate {
  id              Int         @id @default(autoincrement())
  name            String
  description     String?
  isPublic        Boolean     @default(false)
  durationWeeks   Int?
  useRIR          Boolean     @default(false)
  useRPE          Boolean     @default(false)
  useDuration     Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeks           BlockWeek[]

  @@index([userId])
  @@index([isPublic])
}

model BlockWeek {
  id              Int            @id @default(autoincrement())
  order           Int
  blockTemplateId Int
  blockTemplate   BlockTemplate  @relation(fields: [blockTemplateId], references: [id], onDelete: Cascade)
  workouts        BlockWorkout[]

  @@unique([blockTemplateId, order])
  @@index([blockTemplateId])
}

model BlockWorkout {
  id            Int                    @id @default(autoincrement())
  order         Int
  name          String
  blockWeekId   Int
  blockWeek     BlockWeek              @relation(fields: [blockWeekId], references: [id], onDelete: Cascade)
  exercises     BlockWorkoutExercise[]

  @@unique([blockWeekId, order])
  @@index([blockWeekId])
}

model BlockWorkoutExercise {
  id               Int               @id @default(autoincrement())
  order            Int
  exerciseName     String
  exerciseId       String?
  exercise         Exercise?         @relation(fields: [exerciseId], references: [id], onDelete: SetNull)
  userExerciseId   Int?
  userExercise     UserExercise?     @relation(fields: [userExerciseId], references: [id], onDelete: SetNull)
  targetSets       Int?
  targetReps       String?
  notes            String?
  blockWorkoutId   Int
  blockWorkout     BlockWorkout      @relation(fields: [blockWorkoutId], references: [id], onDelete: Cascade)
  blockWorkoutSets BlockWorkoutSet[]

  @@unique([blockWorkoutId, order])
  @@index([blockWorkoutId])
  @@index([exerciseId])
  @@index([userExerciseId])
}

model UserExercise {
  id                    Int                    @id @default(autoincrement())
  userId                String
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                  String
  normalizedName        String
  muscles               Json
  createdAt             DateTime               @default(now())
  templateExercises     TemplateExercise[]
  sessionExercises      SessionExercise[]
  blockWorkoutExercises BlockWorkoutExercise[]

  @@unique([userId, normalizedName])
  @@index([userId])
}

/// Vendored Free Exercise DB catalog (server/data/exercises.json), seeded by
/// prisma/seed.js (idempotent upserts). Standalone in A1 - FK linkage from the
/// exerciseName-carrying models is the separate A4 unit.
model Exercise {
  id                    String                 @id
  name                  String
  force                 String?
  level                 String?
  mechanic              String?
  equipment             String?
  category              String?
  primaryMuscles        String[]
  secondaryMuscles      String[]
  instructions          String[]
  images                String[]
  muscleWeights         Json?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  templateExercises     TemplateExercise[]
  sessionExercises      SessionExercise[]
  blockWorkoutExercises BlockWorkoutExercise[]

  @@index([name])
}

model BlockWorkoutSet {
  id                     Int                  @id @default(autoincrement())
  order                  Int
  reps                   Float?
  weight                 Float?
  rpe                    Float?
  rir                    Int?
  notes                  String?
  blockWorkoutExerciseId Int
  blockWorkoutExercise   BlockWorkoutExercise @relation(fields: [blockWorkoutExerciseId], references: [id], onDelete: Cascade)
  workoutSets            WorkoutSet[]

  @@unique([blockWorkoutExerciseId, order])
  @@index([blockWorkoutExerciseId])
}
