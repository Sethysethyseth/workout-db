generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  passwordHash     String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  workoutTemplates WorkoutTemplate[]
  workoutSessions  WorkoutSession[]
}

model WorkoutTemplate {
  id          Int                @id @default(autoincrement())
  name        String
  description String?
  isPublic    Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises   TemplateExercise[]
  sessions    WorkoutSession[]

  @@index([userId])
  @@index([isPublic])
}

model TemplateExercise {
  id                Int               @id @default(autoincrement())
  order             Int
  exerciseName      String
  targetSets        Int?
  targetReps        String?
  notes             String?
  workoutTemplateId Int
  workoutTemplate   WorkoutTemplate   @relation(fields: [workoutTemplateId], references: [id], onDelete: Cascade)
  sets              WorkoutSet[]
  sessionExercises  SessionExercise[]

  @@unique([workoutTemplateId, order])
  @@index([workoutTemplateId])
}

model WorkoutSession {
  id                Int               @id @default(autoincrement())
  performedAt       DateTime          @default(now())
  startedAt         DateTime          @default(now())
  completedAt       DateTime?
  notes             String?
  createdAt         DateTime          @default(now())
  userId            String
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutTemplateId Int?
  workoutTemplate   WorkoutTemplate?  @relation(fields: [workoutTemplateId], references: [id], onDelete: SetNull)
  sets              WorkoutSet[]
  sessionExercises  SessionExercise[]

  @@index([userId])
  @@index([workoutTemplateId])
}

model WorkoutSet {
  id                 Int               @id @default(autoincrement())
  order              Int
  reps               Int?
  weight             Float?
  rpe                Float?
  rir                Int?
  notes              String?
  workoutSessionId   Int
  workoutSession     WorkoutSession    @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  templateExerciseId Int?
  templateExercise   TemplateExercise? @relation(fields: [templateExerciseId], references: [id], onDelete: SetNull)
  sessionExerciseId  Int?
  sessionExercise    SessionExercise?  @relation(fields: [sessionExerciseId], references: [id], onDelete: SetNull)

  @@unique([workoutSessionId, order])
  @@index([workoutSessionId])
  @@index([templateExerciseId])
  @@index([sessionExerciseId])
}

model SessionExercise {
  id                 Int               @id @default(autoincrement())
  order              Int
  exerciseName       String
  targetSets         Int?
  targetReps         String?
  notes              String?
  workoutSessionId   Int
  workoutSession     WorkoutSession    @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  templateExerciseId Int?
  templateExercise   TemplateExercise? @relation(fields: [templateExerciseId], references: [id], onDelete: SetNull)
  sets               WorkoutSet[]

  @@unique([workoutSessionId, order])
  @@index([workoutSessionId])
  @@index([templateExerciseId])
}
